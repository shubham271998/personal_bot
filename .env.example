# ── Pocket Telegram Bot — Configuration ──────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required ─────────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (send /start to the bot to see it)
# Comma-separated for multiple users. REQUIRED — bot rejects all users if empty.
ALLOWED_TELEGRAM_IDS=

# Chat ID for startup notifications & security alerts
SECURITY_ALERT_CHAT_ID=

# ── Security ─────────────────────────────────────────────────
# Encryption key for user API keys at rest (IMPORTANT: generate a random one)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
USER_ENCRYPT_KEY=

# ── Optional ─────────────────────────────────────────────────
# Default project directory for Claude
PROJECT_DIR=

# Rate limiting (per user)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# Voice transcription
WHISPER_MODEL=base

# Claude CLI permissions (set to "true" ONLY in sandboxed environments)
CLAUDE_SKIP_PERMISSIONS=true

# Claude execution timeout (ms) — kills runaway sessions
CLAUDE_TIMEOUT_MS=300000

# Log level: DEBUG, INFO, WARN, ERROR
LOG_LEVEL=INFO
